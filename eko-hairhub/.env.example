# ============================================================
# EKO HAIRHUB — Frontend Environment Variables
# Copy this file to .env.local and fill in your values
# ============================================================

# API Base URL
NEXT_PUBLIC_API_URL=http://localhost:5000/api

# Paystack Public Key (safe to expose in frontend)
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# App URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Cloudinary (public, for direct uploads if needed)
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your-cloud-name
